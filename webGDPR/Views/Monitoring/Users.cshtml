@model webGDPR.ViewModels.MonitoringUsersViewModel
@{
	ViewData["Title"] = "Monitoring Page";
}
<h2>
	<i class="fa fa-heartbeat fa-fw" aria-hidden="true"></i>&nbsp; Monitoring
</h2>
<div class="row">
	<div class="col-md-12">
		<h2>Users</h2>
		<form asp-action="Index" method="get">
			<div class="form-actions no-color">
				<p>
					Find:
					<input type="text" name="SearchString" value="@Model.CurrentFilter" />
					<input type="submit" value="Search" class="btn btn-default" /> |
					<a asp-action="Index">Back to full List</a>
				</p>
			</div>
		</form>
		<table class="table">
			<thead>
				<tr>
					<th scope="col">UserId</th>
					<th scope="col">Name</th>
					<th scope="col">Missing Subscription</th>
					<th scope="col"></th>

				</tr>
			</thead>
			<tbody>
				@foreach (webGDPR.Models.User u in Model.Users)
			{
				<tr>
					<td>@u.UserID</td>
					<td>@u.Name</td>
					<td>@u.MissingSubscription</td>
					<td>
						@if (u.MissingSubscription)
						{
							<a class="btn btn-default" asp-action="MissingSubscriptionOff" asp-route-id="@u.UserID">Subscription Paid</a>
						}
						else
						{
							<a class="btn btn-danger active" asp-action="MissingSubscriptionOn" asp-route-id="@u.UserID">Missing Subscription</a>
						}
					</td>
				</tr>
		}
			</tbody>
		</table>
		@{
		var prevDisabled = !Model.Users.HasPreviousPage ? "disabled" : "";
		var nextDisabled = !Model.Users.HasNextPage ? "disabled" : "";
		}

		<a asp-action="Index"
		   asp-route-pageIndex="@(Model.Users.PageIndex - 1)"
		   asp-route-currentFilter="@Model.CurrentFilter"
		   class="btn btn-default @prevDisabled">
			Previous
		</a>
		<a asp-action="Index"
		   asp-route-pageIndex="@(Model.Users.PageIndex + 1)"
		   asp-route-currentFilter="@Model.CurrentFilter"
		   class="btn btn-default @nextDisabled">
			Next
		</a>
	</div>
</div>
