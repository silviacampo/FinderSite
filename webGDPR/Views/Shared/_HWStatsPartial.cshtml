@model webGDPR.ViewModels.HWOverviewViewModel
@using webGDPR.ViewModels;
@using Microsoft.AspNetCore.Mvc.Localization

@inject IViewLocalizer Localizer

<script>
	var names = JSON.parse('@Html.Raw(Json.Serialize(Model.DeviceStats.Select(b => b.Device.GetName).ToArray()))');
	var deviceconnectedTimes = JSON.parse('@Html.Raw(Json.Serialize(Model.DeviceStats.Select(b => b.AvgConnected).ToArray()))');
	//"rgba(75, 192, 192, 1)" "rgba(255, 206, 86, 1)" "rgba(255, 99, 132, 1)"
	//"rgba(75, 192, 192, 0.2)" "rgba(255, 206, 86, 0.2)" "rgba(255, 99, 132, 0.2)"
	var devicesconnectedbackground = [];
	var devicesconnectedborder = [];
	@foreach (DeviceStats p in Model.DeviceStats) {
		string colorbackground = string.Empty;
		string colorborder = string.Empty;
		if (p.AvgConnected > 50)
		{
			colorbackground = "rgba(75, 192, 192, 0.2)";
			colorborder = "rgba(75, 192, 192, 1)";
		}
		else if (p.AvgConnected > 20)
		{
			colorbackground = "rgba(255, 206, 86, 0.2)";
			colorborder = "rgba(255, 206, 86, 1)";
		}
		else {
			colorbackground = "rgba(255, 99, 132, 0.2)";
			colorborder = "rgba(255, 99, 132, 1)";
		}
		<text>
			devicesconnectedbackground.push('@colorbackground');
			devicesconnectedborder.push('@colorborder');
		</text>
	}

	var radios = JSON.parse('@Html.Raw(Json.Serialize(Model.BaseStats.Select(b => b.AvgRadio).ToArray()))');
			var namesCollars = JSON.parse('@Html.Raw(Json.Serialize(Model.CollarStats.Select(b => b.Collar.Name).ToArray()))');
			var disconnectedTimesCollars = JSON.parse('@Html.Raw(Json.Serialize(Model.CollarStats.Select(b => b.DisconnectedTimeSpan.TotalMinutes).ToArray()))');
			var gpsDisconnectedTimesCollars = JSON.parse('@Html.Raw(Json.Serialize(Model.CollarStats.Select(b => b.GPSDisconnectedTimeSpan.TotalMinutes).ToArray()))');
			var radiosCollars = JSON.parse('@Html.Raw(Json.Serialize(Model.CollarStats.Select(b => b.AvgRadio).ToArray()))');
			var batteryCollars = JSON.parse('@Html.Raw(Json.Serialize(Model.CollarStats.Select(b => b.AvgBattery).ToArray()))');
</script>
<style>
	.chart {
		position: relative;
		display: inline-block;
		width: 80px;
		height: 80px;
		margin-top: 10px;
		margin-bottom: 10px;
		text-align: center;
	}

		.chart canvas {
			position: absolute;
			top: 0;
			left: 0;
		}

	.percent {
		display: inline-block;
		line-height: 80px;
		z-index: 2;
	}

		.percent:after {
			content: '%';
			margin-left: 0.1em;
			font-size: .8em;
		}
</style>

<div class="overlay" style="position: absolute; width:100%;height:100%;margin-left:-23px;margin-right:23px;margin-top:-23px;margin-bottom:23px;"></div>
<div id="loader"></div>

<div class="well well-lg" style="background-color: white;">
	<h4><i class="fa fa-mobile-alt fa-fw" aria-hidden="true"></i> &nbsp;@Localizer["Connected Time of Mobile Devices or Computers running the applicationw"]</h4>
	<canvas id="horizontalBar" height="80px"></canvas>
</div>

<div class="well well-lg" style="background-color: white;">
	<h4>
		<i class="fa fa-home fa-fw" aria-hidden="true"></i> &nbsp; @Localizer["Bases Performances"]
	</h4>
	<hr />
	@foreach (BaseStats bs in Model.BaseStats)
	{
		<div class="row">
			<div class="col-md-3 col-sm-3" style="text-align: center; vertical-align:middle;">
				@bs.Base.Name
			</div>
			<div class="col-md-3 col-sm-3" style="text-align: center;">
				<span class="chart" data-percent="@bs.AvgConnected" data-bar-color="@(bs.AvgConnected > 75? "rgba(75, 192, 192, 1)" :(bs.AvgConnected > 50? "rgba(255, 206, 86, 1)":"rgba(255, 99, 132, 1)"))" data-line-width="10" data-size="80">
					<span class="percent">@bs.AvgConnected</span>
				</span>
				<span class="label label-default">@Localizer["Network Connected"]</span>
			</div>
			<div class="col-md-3 col-sm-3" style="text-align: center;">
				<span class="chart" data-percent="@bs.AvgPlugIn" data-bar-color="@(bs.AvgPlugIn > 75? "rgba(75, 192, 192, 1)" :(bs.AvgPlugIn > 50? "rgba(255, 206, 86, 1)":"rgba(255, 99, 132, 1)"))" data-line-width="10" data-size="80">
					<span class="percent">@bs.AvgPlugIn</span>
				</span>
				<span class="label label-default">@Localizer["Power Connected"]</span>
			</div>
			<div class="col-md-3 col-sm-3" style="text-align: center;">
				<span class="chart" data-percent="@bs.AvgRadio" data-bar-color="@(bs.AvgRadio > 60? "rgba(75, 192, 192, 1)" :(bs.AvgRadio > 40? "rgba(255, 206, 86, 1)":"rgba(255, 99, 132, 1)"))" data-line-width="10" data-size="80">
					<span class="percent">@bs.AvgRadio</span>
				</span>
				<span class="label label-default">@Localizer["Average Radio Strenght"]</span>
			</div>
		</div>
	}

</div>
<div class="well well-lg" style="background-color: white;">
	<h4>
		<i class="fa fa-paw fa-fw" aria-hidden="true"></i> &nbsp; @Localizer["Collars on Pets Performances"]
	</h4>
	<hr />
	@foreach (CollarStats cs in Model.CollarStats)
	{
		<div class="row">
			<div class="col-md-2 col-sm-2" style="text-align: center; vertical-align:middle;">
				@cs.Collar.Name
			</div>
		</div>
		<div class="row">
			<div class="col-md-3 col-sm-3" style="text-align: center;">
				<span class="chart" data-percent="@cs.AvgConnected" data-bar-color="@(cs.AvgConnected > 75? "rgba(75, 192, 192, 1)" :(cs.AvgConnected > 50? "rgba(255, 206, 86, 1)":"rgba(255, 99, 132, 1)"))" data-line-width="10" data-size="80">
					<span class="percent">@cs.AvgConnected</span>
				</span>
				<span class="label label-default">@Localizer["Network Connected"]</span>
			</div>
			<div class="col-md-3 col-sm-3" style="text-align: center;">
				<span class="chart" data-percent="@cs.AvgGPSConnected" data-bar-color="@(cs.AvgGPSConnected > 60? "rgba(75, 192, 192, 1)" :(cs.AvgGPSConnected > 40? "rgba(255, 206, 86, 1)":"rgba(255, 99, 132, 1)"))" data-line-width="10" data-size="80">
					<span class="percent">@cs.AvgGPSConnected</span>
				</span>
				<span class="label label-default">@Localizer["GPS Connected"]</span>
			</div>
			<div class="col-md-3 col-sm-3" style="text-align: center;">
				<span class="chart" data-percent="@cs.AvgBattery" data-bar-color="@(cs.AvgBattery > 25? "rgba(75, 192, 192, 1)" :(cs.AvgBattery > 10? "rgba(255, 206, 86, 1)":"rgba(255, 99, 132, 1)"))" data-line-width="10" data-size="80">
					<span class="percent">@cs.AvgBattery</span>
				</span>
				<span class="label label-default">@Localizer["Average Battery Charge"]</span>
			</div>
			<div class="col-md-3 col-sm-3" style="text-align: center;">
				<span class="chart" data-percent="@cs.AvgRadio" data-bar-color="@(cs.AvgRadio > 60? "rgba(75, 192, 192, 1)" :(cs.AvgRadio > 40? "rgba(255, 206, 86, 1)":"rgba(255, 99, 132, 1)"))" data-line-width="10" data-size="80">
					<span class="percent">@cs.AvgRadio</span>
				</span>
				<span class="label label-default">@Localizer["Average Radio Strenght"]</span>
			</div>
		</div>
	}


</div>
