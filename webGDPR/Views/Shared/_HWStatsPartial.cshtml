@model webGDPR.ViewModels.HWOverviewViewModel
@{
	ViewData["Title"] = "_HWStats";
}
<script>
	var names = JSON.parse('@Html.Raw(Json.Serialize(Model.BaseStats.Select(b => b.Base.Name).ToArray()))');
	var disconnectedTimes = JSON.parse('@Html.Raw(Json.Serialize(Model.BaseStats.Select(b => b.DisconnectedTimeSpan.TotalMinutes).ToArray()))');
			var radios = JSON.parse('@Html.Raw(Json.Serialize(Model.BaseStats.Select(b => b.AvgRadio).ToArray()))');

			var namesCollars = JSON.parse('@Html.Raw(Json.Serialize(Model.CollarStats.Select(b => b.Collar.Name).ToArray()))');
			var disconnectedTimesCollars = JSON.parse('@Html.Raw(Json.Serialize(Model.CollarStats.Select(b => b.DisconnectedTimeSpan.TotalMinutes).ToArray()))');
			var gpsDisconnectedTimesCollars = JSON.parse('@Html.Raw(Json.Serialize(Model.CollarStats.Select(b => b.GPSDisconnectedTimeSpan.TotalMinutes).ToArray()))');
			var radiosCollars = JSON.parse('@Html.Raw(Json.Serialize(Model.CollarStats.Select(b => b.AvgRadio).ToArray()))');
			var batteryCollars = JSON.parse('@Html.Raw(Json.Serialize(Model.CollarStats.Select(b => b.AvgBattery).ToArray()))');
</script>
<style>
	.chart {
		position: relative;
		display: inline-block;
		width: 80px;
		height: 80px;
		margin-top: 10px;
		margin-bottom: 10px;
		text-align: center;
	}

		.chart canvas {
			position: absolute;
			top: 0;
			left: 0;
		}

	.percent {
		display: inline-block;
		line-height: 80px;
		z-index: 2;
	}

		.percent:after {
			content: '%';
			margin-left: 0.1em;
			font-size: .8em;
		}
</style>
<div class="well well-lg" style="background-color: white;">
	<h3>
		<i class="fa fa-home fa-fw" aria-hidden="true"></i>
	</h3>
	<hr />
	<div class="row">
		<div class="col-md-3 col-sm-3" style="text-align: center; vertical-align:middle;">
			@Model.BaseStats[0].Base.Name
		</div>
		<div class="col-md-3 col-sm-3" style="text-align: center;">
			<span class="chart" data-percent="@Model.BaseStats[0].AvgConnected" data-bar-color="rgb(201, 203, 207)" data-line-width="10" data-size="80">
				<span class="percent">@Model.BaseStats[0].AvgConnected</span>
			</span>
			<span class="label label-default">Network Connected</span>
		</div>
		<div class="col-md-3 col-sm-3" style="text-align: center;">
			<span class="chart" data-percent="@Model.BaseStats[0].AvgPlugIn" data-bar-color="rgb(201, 203, 207)" data-line-width="10" data-size="80">
				<span class="percent">@Model.BaseStats[0].AvgPlugIn</span>
			</span>
			<span class="label label-default">Power Connected</span>
		</div>
		<div class="col-md-3 col-sm-3" style="text-align: center;">
			<span class="chart" data-percent="@Model.BaseStats[0].AvgRadio" data-bar-color="rgb(201, 203, 207)" data-line-width="10" data-size="80">
				<span class="percent">@Model.BaseStats[0].AvgRadio</span>
			</span>
			<span class="label label-default">Medium Radio Strenth</span>
		</div>
	</div>
</div>
<div class="well well-lg" style="background-color: white;">
	<h3>
		<i class="fa fa-paw fa-fw" aria-hidden="true"></i>
	</h3>
	<hr />
	<div class="row">
		<div class="col-md-2 col-sm-2" style="text-align: center; vertical-align:middle;">
			@Model.CollarStats[0].Collar.Name
		</div>
	</div>
	<div class="row">
		<div class="col-md-3 col-sm-3" style="text-align: center;">
			<span class="chart" data-percent="@Model.CollarStats[0].AvgConnected" data-bar-color="rgb(201, 203, 207)" data-line-width="10" data-size="80">
				<span class="percent">@Model.CollarStats[0].AvgConnected</span>
			</span>
			<span class="label label-default">Network Connected</span>
		</div>
		<div class="col-md-3 col-sm-3" style="text-align: center;">
			<span class="chart" data-percent="@Model.CollarStats[0].AvgGPSConnected" data-bar-color="rgb(201, 203, 207)" data-line-width="10" data-size="80">
				<span class="percent">@Model.CollarStats[0].AvgGPSConnected</span>
			</span>
			<span class="label label-default">GPS Connected</span>
		</div>
		<div class="col-md-3 col-sm-3" style="text-align: center;">
			<span class="chart" data-percent="@Model.CollarStats[0].AvgBattery" data-bar-color="rgb(201, 203, 207)" data-line-width="10" data-size="80">
				<span class="percent">@Model.CollarStats[0].AvgBattery</span>
			</span>
			<span class="label label-default">Medium Battery Charge</span>
		</div>
		<div class="col-md-3 col-sm-3" style="text-align: center;">
			<span class="chart" data-percent="@Model.CollarStats[0].AvgRadio" data-bar-color="rgb(201, 203, 207)" data-line-width="10" data-size="80">
				<span class="percent">@Model.CollarStats[0].AvgRadio</span>
			</span>
			<span class="label label-default">Medium Radio Strenth</span>
		</div>
	</div>

</div>
