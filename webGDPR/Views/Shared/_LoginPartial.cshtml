@using Microsoft.AspNetCore.Identity
@using webGDPR.Data;
@using Microsoft.AspNetCore.Mvc.Localization

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IViewLocalizer Localizer

@if (SignInManager.IsSignedIn(User))
{
	<form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" id="logoutForm" class="navbar-right">
		<ul class="nav navbar-nav">
			@if (!((await UserManager.GetUserAsync(User)).MissingSubscription))
			{
				<li><a asp-area="" asp-controller="User" asp-action="Dashboard" title='@Localizer["Dashboard"]'><i class="fa fa-tachometer-alt fa-fw" aria-hidden="true"></i>&nbsp; @*@Localizer["Dashboard"]*@</a></li>
				<li><a asp-area="" asp-controller="User" asp-action="HWOverview" title='@Localizer["Performance Overview"]'><i class="fa fa-chart-line fa-fw" aria-hidden="true"></i>&nbsp; @*@Localizer["Performance Overview"]*@</a></li>
				<li><a asp-area="" asp-controller="User" asp-action="ConnectionTimeline" title='@Localizer["Comunication Timeline"]'><i class="fa fa-clock fa-fw" aria-hidden="true"></i>&nbsp; @*@Localizer["Comunication Timeline"]*@</a></li>
				<li><a asp-area="" asp-controller="User" asp-action="PickLocation" title='@Localizer["Pick a location"]'><i class="fa fa-location-arrow fa-fw" aria-hidden="true"></i>&nbsp; @*@Localizer["Pick a location"]*@</a></li>
			}
		</ul>
		<ul class="nav navbar-nav">
			<li class="dropdown">
				<a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false" title='@Localizer["Admin Section"]'><i class="fa fa-cogs fa-fw" aria-hidden="true"></i>&nbsp; @*@Localizer["Admin Section"]*@<span class="caret"></span></a>
				<ul class="dropdown-menu">
					<li><a asp-area="" asp-controller="Monitoring" asp-action="Index" title='@Localizer["Monitoring"]'><i class="fa fa-heartbeat fa-fw" aria-hidden="true"></i>&nbsp; @Localizer["Monitoring"]</a></li>
					<li><a asp-area="" asp-controller="Monitoring" asp-action="WebSocketClient" title='@Localizer["Web Socket Client"]'><i class="fa fa-robot fa-fw" aria-hidden="true"></i>&nbsp; @Localizer["Web Socket Client"]</a></li>
					<li><a asp-area="" asp-controller="Monitoring" asp-action="ChangeConfig" title='@Localizer["Change Configuration"]'><i class="fa fa-cog fa-fw" aria-hidden="true"></i>&nbsp; @Localizer["Change Configuration"]</a></li>
					<li><a asp-area="" asp-controller="Pet" asp-action="Index" title='@Localizer["Pets"]'><i class="fa fa-paw fa-fw" aria-hidden="true"></i>&nbsp; @Localizer["Pets"]</a></li>
					<li><a asp-area="" asp-controller="Collar" asp-action="Index" title='@Localizer["Collars"]'><i class="fa fa-map-marker fa-fw" aria-hidden="true"></i>&nbsp; @Localizer["Collars"]</a></li>
					<li><a asp-area="" asp-controller="Base" asp-action="Index" title='@Localizer["Bases"]'><i class="fa fa-home fa-fw" aria-hidden="true"></i>&nbsp; @Localizer["Bases"]</a></li>
					<li><a asp-area="" asp-controller="Device" asp-action="Index" title='@Localizer["Devices"]'><i class="fa fa-mobile-alt fa-fw" aria-hidden="true"></i>&nbsp; @Localizer["Devices"]</a></li>
					<li><a asp-area="" asp-controller="Monitoring" asp-action="Users" title='@Localizer["Users"]'><i class="fa fa-users fa-fw" aria-hidden="true"></i>&nbsp; @Localizer["Users"]</a></li>
					<li><a asp-area="" asp-controller="Monitoring" asp-action="Upload" title='@Localizer["Upload Files"]'><i class="fa fa-file fa-fw" aria-hidden="true"></i>&nbsp; @Localizer["Upload Files"]</a></li>
					<li><a asp-area="" asp-controller="Product" asp-action="Index" title='@Localizer["Products"]'><i class="fa fa-cube fa-fw" aria-hidden="true"></i>&nbsp; @Localizer["Products"]</a></li>
				</ul>
			</li>
		</ul>
		<ul class="nav navbar-nav navbar-right">
			<li>
				<a asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
					Hello @UserManager.GetUserName(User)! @if (((await UserManager.GetUserAsync(User)).MissingSubscription))
					{
						<b>@Localizer["Missing Subscription"]</b>
					}
				</a>
			</li>
			<li>
				<a asp-area="" asp-controller="Home" asp-action="Chat" data-toggle="chat" data-collapse-sidebar="1" title='@Localizer["Notifications"]'>
					<i class="fa fa-comments fa-fw"></i>&nbsp;@*@Localizer["Notifications"]&nbsp;*@<span class="badge badge-success chat-notifications-badge">3</span>
				</a>
				<a href="#chatModal" data-backdrop="false" data-toggle="modal">Talk</a>
			</li>
			<li>
				<button type="submit" class="btn btn-link navbar-btn navbar-link" title="@Localizer["Logout"]"><i class="fa fa-sign-out-alt fa-fw" aria-hidden="true"></i>&nbsp; @*@Localizer["Logout"]*@</button>
			</li>
		</ul>
	</form>
}
else
{
	<ul class="nav navbar-nav navbar-right">
		<li><a asp-area="Identity" asp-page="/Account/Register" title="@Localizer["Register"]"><i class="fa fa-user-plus fa-fw" aria-hidden="true"></i>&nbsp; @*@Localizer["Register"]*@</a></li>
		<li><a asp-area="Identity" asp-page="/Account/Login" title="@Localizer["Login"]"><i class="fa fa-sign-in-alt fa-fw" aria-hidden="true"></i>&nbsp; @*@Localizer["Login"]*@</a></li>
	</ul>
}