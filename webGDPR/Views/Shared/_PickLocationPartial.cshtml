@model User
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer



@if (!string.IsNullOrEmpty(Model.FormattedAddress))
{
	<p>@Localizer["This is your current location:"]</p>
	<div class="well well-lg">@Model.FormattedAddress</div>
	<p>@Localizer["If it's wrong, please enter your current location below and click Update."]</p>
	<hr />
}
else
{
	<p>@Localizer["Please enter your current location below and click Update."]</p>
}
<div class="row">
	<form asp-controller="User" asp-action="PickLocation" enctype="multipart/form-data">
		<div class="col-md-8">
			<div asp-validation-summary="ModelOnly" class="text-danger"></div>
			<div class="form-group">
				<label asp-for="FormattedAddress" class="control-label"></label>
				<input asp-for="FormattedAddress" class="form-control" />
				<span asp-validation-for="FormattedAddress" class="text-danger"></span>
			</div>
			<div class="form-group">
				<input type="submit" value="Update" class="btn btn-default" />
			</div>

		</div>
	</form>
</div>



