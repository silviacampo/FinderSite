@model webGDPR.Models.Device

@{
	ViewData["Title"] = "Edit a mobile device or computer";
}
<div class="row">
	<div class="col-md-4">
		<fieldset class="myfieldset">
			<h4><i class="fa fa-mobile-alt fa-fw" aria-hidden="true"></i>&nbsp;@ViewData["Title"]</h4>
			<hr />
			<form asp-action="Edit">
				<div asp-validation-summary="ModelOnly" class="text-danger"></div>
				<input type="hidden" asp-for="DeviceId" />
				<div class="form-group">
					<label asp-for="Type" class="control-label"></label>
					<input asp-for="Type" readonly="readonly" class="form-control" />
					<span asp-validation-for="Type" class="text-danger"></span>
				</div>
				<div class="form-group">
					<label asp-for="Platform" class="control-label"></label>
					<input asp-for="Platform" readonly="readonly" class="form-control" />
					<span asp-validation-for="Platform" class="text-danger"></span>
				</div>
				<div class="form-group">
					<label asp-for="Name" class="control-label"></label>
					<input asp-for="Name" readonly="readonly" class="form-control" />
					<span asp-validation-for="Name" class="text-danger"></span>
				</div>
				<div class="form-group">
					<label asp-for="Model" class="control-label"></label>
					<input asp-for="Model" readonly="readonly" class="form-control" />
					<span asp-validation-for="Model" class="text-danger"></span>
				</div>
				<div class="form-group">
					<label asp-for="Manufacturer" class="control-label"></label>
					<input asp-for="Manufacturer" readonly="readonly" class="form-control" />
					<span asp-validation-for="Manufacturer" class="text-danger"></span>
				</div>
				<div class="form-group">
					<label asp-for="OSVersion" class="control-label"></label>
					<input asp-for="OSVersion" readonly="readonly" class="form-control" />
					<span asp-validation-for="OSVersion" class="text-danger"></span>
				</div>
				<div class="form-group">
					<label asp-for="AliasName" class="control-label"></label>
					<input asp-for="AliasName" class="form-control" />
					<span asp-validation-for="AliasName" class="text-danger"></span>
				</div>
				@*<div class="form-group">
					<div class="checkbox">
						<label>
							<input asp-for="Banned" /> @Html.DisplayNameFor(model => model.Banned)
						</label>
					</div>
				</div>
				<div class="form-group">
					<div class="checkbox">
						<label>
							<input asp-for="IsLogging" /> @Html.DisplayNameFor(model => model.IsLogging)
						</label>
					</div>
				</div>*@
				@*<div class="form-group">
				<label asp-for="UserId" class="control-label"></label>
				<input asp-for="UserId" class="form-control" />
				<span asp-validation-for="UserId" class="text-danger"></span>
			</div>*@
				<div class="form-group">
					<input type="submit" value="Save" class="btn btn-default" />
				</div>
			</form>
		</fieldset>
	</div>
</div>

