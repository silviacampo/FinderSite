@model User
@{
	ViewData["Title"] = "Dashboard";
}

<h2>
	<i class="fa fa-tachometer-alt fa-fw" aria-hidden="true"></i>&nbsp; @ViewData["Title"]
</h2>

<div class="row">
	<div class="col-md-3">
		<h2>Issues</h2>
		<ul class="errorlist-ul">
			@{
				List<webGDPR.Infrastructure.CustomWebSockets.CustomWebSocket> WebSockets = (List<webGDPR.Infrastructure.CustomWebSockets.CustomWebSocket>)ViewData["WebSockets"];
				if (WebSockets.Count <= 0) {
			<li>
				<b>No Device is connected</b>
			</li>
				}
			}

			@if (Model.MissingSubscription)
			{
				<li>
					<b><a asp-action="FixMissingSubscription">Missing Subscription</a></b>
				</li>
			}
			@if (Model.Bases.Count() + @Model.Collars.Count() == 0)
			{
				<li>
					<b>Missing Initialization</b>
				</li>
			}
			@if (Model.Devices.Count() == 0)
			{
				<li>
					<b>Missing Install app</b>
				</li>
			}
			@if (Model.Latitude == 0 && Model.Longitude == 0)
			{
				<li>
					<b>Missing user location</b>
				</li>
			}

			@if (Model.Pets.Any(b => b.LastMode != null && b.LastMode.Type == ConfigModeTypes.Emergency && b.LastMode.IsActive))
			{
				<li>
					<b>Pet lost</b>
				</li>
			}
			@if (Model.Bases.Any(b => b.LastStatus == null || !b.LastStatus.IsConnected))
			{
				<li>
					<b>Bases Disconnected</b>
				</li>
			}
			@if (Model.Collars.Any(b => b.LastStatus == null || !b.LastStatus.IsConnected))
			{
				<li>
					<b>Collars Disconnected</b>
				</li>
			}
			@if (Model.Pets.Any(b => b.LastTrackingInfo == null || b.LastTrackingInfo.CreationDate.AddDays(1) < DateTime.Now))
			{
				<li>
					<b>Pet not moving the last 24 h</b>
				</li>
			}
			@if (Model.Collars.Any(b => b.LastStatus != null && b.LastStatus.Battery < 30))
			{
				<li>
					<b>Collars with battery less than 30%</b>
				</li>
			}
			@if (Model.Collars.Any(b => b.LastStatus != null && b.LastStatus.Radio < 20) || Model.Bases.Any(b => b.LastStatus != null && b.LastStatus.Radio < 20))
			{
				<li>
					<b>Collars with lora failing to connect</b>
				</li>
			}
			@if (Model.Collars.Any(b => b.LastStatus != null && b.LastStatus.IsNotGPSConnected))
			{
				<li>
					<b>Collars with GPS failing to connect</b>
				</li>
			}
		</ul>
		<h2>Actions</h2>
		<ul class="actionlist-ul">
			<li><a asp-area="" asp-controller="User" asp-action="PickLocation" target="_blank"><i class="fa fa-location-arrow fa-fw" aria-hidden="true"></i>&nbsp; Update your Location</a></li>
			<li><a asp-area="" asp-controller="Device" asp-action="DownloadApp" target="_blank"><i class="fa fa-download fa-fw" aria-hidden="true"></i>&nbsp; Download mobile and desktop application</a></li>
			<li><a asp-area="" asp-controller="Order" asp-action="Create" target="_blank"><i class="fa fa-cart-plus fa-fw" aria-hidden="true"></i>&nbsp; Buy another base or collar</a></li>
			<li><a asp-area="" asp-controller="Base" asp-action="Create" target="_blank"><i class="fa fa-home fa-fw" aria-hidden="true"></i>&nbsp; Add a base</a></li>
			<li><a asp-area="" asp-controller="Collar" asp-action="Create" target="_blank"><i class="fa fa-medal fa-fw" aria-hidden="true"></i>&nbsp; Add a collar</a></li>
			<li>
				<a asp-area="" asp-controller="Pet" asp-action="Create" target="_blank"><i class="fa fa-paw fa-fw" aria-hidden="true"></i>&nbsp; Add a Pet</a>
				@if (Model.Pets.Count() == 0)
				{<b>You haven't create any pet....</b>}
			</li>			
		</ul>
	</div>
	<div class="col-md-6">
		<h2>Overview</h2>
		<div class="well well-lg" style="position:relative;top:0px;left:0px; min-width:200px;">
			<table class="table" style="position:relative;top:0px;left:0px; min-width:120px;">
				<theader>
					<tr>
						<th>
							<i class="fa fa-mobile-alt fa-fw" aria-hidden="true"></i> &nbsp; Mobile devices or computers running the application
						</th>
						<th class="small">Network Connected</th>
						<th class="small" style="min-width:80px;">Actions</th>
					</tr>
				</theader>
				<tbody>
					@{
						foreach (Device d in Model.Devices)
						{
					<tr>
						<td>
							<div style="position:relative;top:0px;left:0px; min-width:40px;">
								@d.GetPlatform @d.GetName
							</div>
						</td>

						<td>
							@if (WebSockets.Exists(w => w.DeviceId == d.DeviceId))
							{
								<i class="fa fa-circle fa-fw" style="color:green;position:relative;top:7px;left:0px" aria-hidden="true"></i>
							}
							else
							{
								<i class="fa fa-circle fa-fw" style="color:red;position:relative;top:7px;left:0px" aria-hidden="true"></i>
							}
						</td>
						<td>
							<a asp-controller="Device" asp-action="Edit" asp-route-id="@d.DeviceId" title="Edit" target="_blank"><i class="fa fa-edit fa-fw" aria-hidden="true"></i></a>
							@if (d.Banned)
							{
								<a class="unBan" data-id="@d.DeviceId" data-name="@d.GetName" title="Authorize to connect"><i class="fa fa-check-circle fa-fw" aria-hidden="true"></i></a>
								<a class="openBanDialog" data-id="@d.DeviceId" data-name="@d.GetName" title="Do no authorize to connect" style="display:none;"><i class="fa fa-ban fa-fw" aria-hidden="true"></i></a>
							}
							else
							{
								<a class="unBan" data-id="@d.DeviceId" data-name="@d.GetName" title="Authorize to connect" style="display:none;"><i class="fa fa-check-circle fa-fw" aria-hidden="true"></i></a>
								<a class="openBanDialog" data-id="@d.DeviceId" data-name="@d.GetName" title="Do no authorize to connect"><i class="fa fa-ban fa-fw" aria-hidden="true"></i></a>
							}
							<a class="openDeleteDeviceDialog" data-id="@d.DeviceId" data-device="@Newtonsoft.Json.JsonConvert.SerializeObject(d)" title="Delete"><i class="fa fa-trash fa-fw" aria-hidden="true"></i></a>
						</td>
					</tr>
						}

					}
				</tbody>
			</table>
		</div>
		<div class="well well-lg" style="position:relative;top:0px;left:0px; min-width:200px;">
			<table class="table" style="position:relative;top:0px;left:0px; min-width:100px;">
				<theader>
					<tr>
						<th>
							<i class="fa fa-home fa-fw" aria-hidden="true"></i> &nbsp; Bases
						</th>
						<th class="small">Network Connected</th>
						<th class="small visible-md visible-lg visible-sm">Plug in </th>
						<th class="small visible-md visible-lg visible-sm">Charging battery</th>
						<th class="small visible-md visible-lg visible-sm">Radio Strength</th>
						<th class="small" style="min-width:60px;">Actions</th>
					</tr>
				</theader>
				<tbody>
					@foreach (var item in Model.Bases.Where(b => !b.Deleted))
					{
						<tr>
							<td>
								<div style="position:relative;top:0px;left:0px; min-width:110px;">
									@Html.DisplayFor(modelItem => item.Name)
								</div>
							</td>
							<td>
								<div style="position:relative;top:0px;left:0px; min-width:20px;">
									@if (item.LastStatus != null && item.LastStatus.IsConnected)
									{
										<i class="fa fa-circle fa-fw" style="color:green;position:relative;top:7px;left:0px" aria-hidden="true"></i>
										@if (item.LastStatus != null && item.LastStatus.DeviceConnectedTo != null)
										{
											@Html.DisplayFor(modelItem => item.LastStatus.DeviceConnectedTo.GetName)
										}
									}
									else
									{
										<i class="fa fa-circle fa-fw" style="color:red;position:relative;top:7px;left:0px" aria-hidden="true"></i>
									}
								</div>
							</td>
							<td class="visible-md visible-lg visible-sm" valign="middle">
								<div style="position:relative;top:0px;left:0px; min-width:20px;">
									<i class="fa fa-plug fa-fw" style="color:gray;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
									@if (!(item.LastStatus != null && item.LastStatus.IsPlugged))
									{
										<i style="color:black; font-weight:bold; font-size:x-large;padding-top:0px;padding-bottom:0px;position:absolute;top:0px;left:6px">\</i>
									}
								</div>

							</td>
							<td class="visible-md visible-lg visible-sm">
								<div style="position:relative;top:0px;left:0px; min-width:20px;">
									@if (item.LastStatus != null)
									{
										if (item.LastStatus.Battery < 25)
										{
											<i class="fa fa-battery-empty fa-fw" style="color:lightblue;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
										}
										else if (item.LastStatus.Battery < 50)
										{
											<i class="fa fa-battery-quarter fa-fw" style="color:lightblue;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
										}
										else if (item.LastStatus.Battery < 75)
										{
											<i class="fa fa-battery-half fa-fw" style="color:lightblue;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
										}
										else if (item.LastStatus.Battery < 100)
										{
											<i class="fa fa-battery-three-quarters fa-fw" style="color:lightblue;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
										}
										else
										{
											<i class="fa fa-battery-full fa-fw" style="color:lightblue;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
										}
									}
									else
									{
										<i class="fa fa-battery-empty fa-fw" style="color:lightblue;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
									}
									@if (!(item.LastStatus != null && item.LastStatus.HasBattery))
									{
										<i style="color:black; font-weight:bold; font-size:x-large;position:absolute;top:0px;left:4px">\</i>
									}
									@if (item.LastStatus != null && item.LastStatus.IsCharging)
									{
										<i class="fa fa-bolt fa-fw" style="color:black;position:absolute;top:10px;left:0px">\</i>
									}
								</div>

							</td>
							<td class="visible-md visible-lg visible-sm">
								<div style="position:relative;top:0px;left:0px; min-width:20px;">
									<i class="fa fa-signal fa-fw" style="color:gray;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
									@if (item.LastStatus != null)
									{
										<i style="color:black;font-weight:bold;font-size:small;position:absolute;top:5px;left:6px">@item.LastStatus.RadioPercentage</i>
									}
									else
									{
										<i style="color:black;font-weight:bold;font-size:small;position:absolute;top:5px;left:6px">0%</i>
									}
								</div>

							</td>
							<td>
								<a asp-controller="Base" asp-action="Edit" asp-route-id="@item.BaseId" target="_blank"><i class="fa fa-edit fa-fw" aria-hidden="true"></i></a>
								<a class="openDeleteBaseDialog" data-id="@item.BaseId" data-base="@Newtonsoft.Json.JsonConvert.SerializeObject(item)" title="Delete"><i class="fa fa-trash fa-fw" aria-hidden="true"></i></a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
		<div class="well well-lg" style="position:relative;top:0px;left:0px; min-width:200px;">
			<table class="table" style="position:relative;top:0px;left:0px; min-width:120px;">
				<theader>
					<tr>
						<th>
							<i class="fa fa-paw fa-fw" aria-hidden="true"></i> &nbsp; Collars on Pets
						</th>
						<th class="small">Network Connected</th>
						<th class="small visible-md visible-lg visible-sm">GPS Connected</th>
						<th class="small visible-md visible-lg visible-sm">Battery Charge</th>
						<th class="small visible-md visible-lg visible-sm">Radio Strength</th>
						<th class="small" style="min-width:60px;">Actions</th>
					</tr>
				</theader>
				<tbody>
					@foreach (var item in Model.Collars.Where(b => !b.Deleted))
					{
						Pet p = Model.Pets.FirstOrDefault(pet => pet.LastCollar != null && pet.LastCollar.CollarId == item.CollarId && !pet.Deleted);
						<tr>
							<td>
								<div style="position:relative;top:0px;left:0px; min-width:60px;">
									@Html.DisplayFor(modelItem => item.Name)
								</div>
							</td>
							<td>
								<div style="position:relative;top:0px;left:0px; min-width:20px;">
									@if (item.LastStatus != null && item.LastStatus.IsConnected)
									{
										<i class="fa fa-circle fa-fw" style="color:green;position:relative;top:7px;left:0px" aria-hidden="true"></i>
										@if (item.LastStatus != null && item.LastStatus.BaseConnectedTo != null)
										{
											@Html.DisplayFor(modelItem => item.LastStatus.BaseConnectedTo.Name)
										}
									}
									else
									{
										<i class="fa fa-circle fa-fw" style="color:red;position:relative;top:7px;left:0px" aria-hidden="true"></i>
									}
								</div>
							</td>
							<td class="visible-md visible-lg visible-sm" valign="middle">
								<div style="position:relative;top:0px;left:0px; min-width:20px;">
									<i class="fa fa-map-marker fa-fw" style="color:gray;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
									@if (!(item.LastStatus != null && item.LastStatus.IsGPSConnected))
									{
										<i style="color:black; font-weight:bold; font-size:x-large;padding-top:0px;padding-bottom:0px;position:absolute;top:0px;left:6px">\</i>
									}
								</div>
							</td>
							<td class="visible-md visible-lg visible-sm">
								<div style="position:relative;top:0px;left:0px; min-width:20px;">
									@if (item.LastStatus != null)
									{
										if (item.LastStatus.Battery < 25)
										{
											<i class="fa fa-battery-empty fa-fw" style="color:lightblue;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
										}
										else if (item.LastStatus.Battery < 50)
										{
											<i class="fa fa-battery-quarter fa-fw" style="color:lightblue;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
										}
										else if (item.LastStatus.Battery < 75)
										{
											<i class="fa fa-battery-half fa-fw" style="color:lightblue;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
										}
										else if (item.LastStatus.Battery < 100)
										{
											<i class="fa fa-battery-three-quarters fa-fw" style="color:lightblue;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
										}
										else
										{
											<i class="fa fa-battery-full fa-fw" style="color:lightblue;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
										}
									}
									else
									{
										<i class="fa fa-battery-empty fa-fw" style="color:lightblue;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
									}
								</div>
							</td>
							<td class="visible-md visible-lg visible-sm">
								<div style="position:relative;top:0px;left:0px; min-width:20px;">
									<i class="fa fa-signal fa-fw" style="color:gray;position:absolute;top:10px;left:0px" aria-hidden="true"></i>
									@if (item.LastStatus != null)
									{
										<i style="color:black;font-weight:bold;font-size:small;position:absolute;top:5px;left:6px">@item.LastStatus.RadioPercentage</i>
									}
									else
									{
										<i style="color:black;font-weight:bold;font-size:small;position:absolute;top:5px;left:6px">0%</i>
									}
								</div>
							</td>
							<td>
								<a asp-controller="Collar" asp-action="Edit" asp-route-id="@item.CollarId" target="_blank"><i class="fa fa-edit fa-fw" aria-hidden="true"></i></a>
								<a class="openDeleteCollarDialog" data-id="@item.CollarId" data-collar="@Newtonsoft.Json.JsonConvert.SerializeObject(item)" data-pet="@(p==null? string.Empty: p.Name)" title="Delete"><i class="fa fa-trash fa-fw" aria-hidden="true"></i></a>
							</td>
						</tr>
						if (p != null)
						{
						<tr>
							<td>
								on&nbsp; @Html.DisplayFor(modelItem => p.Name)
							</td>
							<td class="visible-md visible-lg visible-sm">
								<a class="btn btn-default" asp-controller="Pet" asp-action="Track" asp-route-id="@p.PetId" target="_blank" style="width:100%; padding:3px 6px 3px 6px" title="Check your pet's last locations"><i class="fa fa-route fa-fw" aria-hidden="true"></i></a>
							</td>
							<td class="visible-md visible-lg visible-sm"><a class="btn btn-default" asp-controller="Pet" asp-action="Stats" asp-route-id="@p.PetId" target="_blank" style="width:100%; padding:3px 6px 3px 6px" title="Monitor your pet's activity"><i class="fa fa-heartbeat fa-fw" aria-hidden="true"></i></a></td>
							<td colspan="2">
								@if (p.LastMode != null && p.LastMode.Type == ConfigModeTypes.Emergency && p.LastMode.IsActive)
								{
									<button class="btn btn-default reportFound" data-id="@p.PetId" data-name="@p.Name" style="width:100%; padding:3px 6px 3px 6px">Report Found</button>
									<button class="btn btn-danger openReportLostDialog" data-id="@p.PetId" data-name="@p.Name" style="width:100%; padding:3px 6px 3px 6px; display:none">Report Lost</button>
								}
								else
								{
									<button class="btn btn-default reportFound" data-id="@p.PetId" data-name="@p.Name" style="width:100%; padding:3px 6px 3px 6px; display:none;">Report Found</button>
									<button class="btn btn-danger openReportLostDialog" data-id="@p.PetId" data-name="@p.Name" style="width:100%; padding:3px 6px 3px 6px">Report Lost</button>
								}
							</td>
							<td>
								<a asp-controller="Pet" asp-action="Edit" asp-route-id="@p.PetId" target="_blank"><i class="fa fa-edit fa-fw" aria-hidden="true"></i></a>
								<a class="openDeletePetDialog" data-id="@p.PetId" data-pet="@Newtonsoft.Json.JsonConvert.SerializeObject(p, Newtonsoft.Json.Formatting.None, new Newtonsoft.Json.JsonSerializerSettings { PreserveReferencesHandling = Newtonsoft.Json.PreserveReferencesHandling.Objects})" data-collar="@item.Name" title="Delete"><i class="fa fa-trash fa-fw" aria-hidden="true"></i></a>
							</td>
						</tr>
						}
						else
						{
							<tr class="missing">
								<td>
									<span style="color:red">Missing Pet</span>
								</td>
							</tr>
						}
					}
					@foreach (var item in Model.Pets.Where(p => !p.Deleted))
					{
						if (item.LastCollar == null)
						{
							<tr class="missing">
								<td>
									<span style="color:red">Missing Collar</span>
								</td>
							</tr>
							<tr>
								<td>
									on&nbsp; @Html.DisplayFor(modelItem => item.Name)
								</td>
								<td class="visible-md visible-lg visible-sm">
									<a class="btn btn-default" asp-controller="Pet" asp-action="Track" asp-route-id="@item.PetId" target="_blank" style="width:100%; padding:3px 6px 3px 6px" title="Check your pet's last locations"><i class="fa fa-route fa-fw" aria-hidden="true"></i></a>
								</td>
								<td class="visible-md visible-lg visible-sm"><a class="btn btn-default" asp-controller="Pet" asp-action="Stats" asp-route-id="@item.PetId" target="_blank" style="width:100%; padding:3px 6px 3px 6px" title="Monitor your pet's activity"><i class="fa fa-heartbeat fa-fw" aria-hidden="true"></i></a></td>
								<td colspan="2">
									@if (item.LastMode != null && item.LastMode.Type == ConfigModeTypes.Emergency && item.LastMode.IsActive)
									{
										<button class="btn btn-default reportFound" data-id="@item.PetId" data-name="@item.Name" style="width:100%; padding:3px 6px 3px 6px">Report Found</button>
										<button class="btn btn-danger openReportLostDialog" data-id="@item.PetId" data-name="@item.Name" style="width:100%; padding:3px 6px 3px 6px; display:none">Report Lost</button>
									}
									else
									{
										<button class="btn btn-default reportFound" data-id="@item.PetId" data-name="@item.Name" style="width:100%; padding:3px 6px 3px 6px; display:none;">Report Found</button>
										<button class="btn btn-danger openReportLostDialog" data-id="@item.PetId" data-name="@item.Name" style="width:100%; padding:3px 6px 3px 6px">Report Lost</button>
									}
								</td>
								<td>
									<a asp-controller="Pet" asp-action="Edit" asp-route-id="@item.PetId" target="_blank"><i class="fa fa-edit fa-fw" aria-hidden="true"></i></a>
									<a class="openDeletePetDialog" data-id="@item.PetId" data-pet="@Newtonsoft.Json.JsonConvert.SerializeObject(item, Newtonsoft.Json.Formatting.None, new Newtonsoft.Json.JsonSerializerSettings { PreserveReferencesHandling = Newtonsoft.Json.PreserveReferencesHandling.Objects})" data-collar="" title="Delete"><i class="fa fa-trash fa-fw" aria-hidden="true"></i></a>
								</td>
							</tr>
						}
					}
				</tbody>
			</table>
		</div>
	</div>
	<div class="col-md-3">
		<h2>&nbsp;</h2>
		<div class="well well-lg">
			<div id="mapContainer" style="height:400px">
				<script>
			var coordinates = [];
			@foreach (Pet p in Model.Pets) {
				if (p.LastTrackingInfo != null)
				{
			 	<text>
				var strDate = new String('@p.LastTrackingInfo.CreationDate.ToString("MM/dd/yyyy hh:mm:ss tt") UTC');
				var localTime = new Date(strDate);
				coordinates.push({ lat: @p.LastTrackingInfo.Latitude, lng: @p.LastTrackingInfo.Longitude, name: "@p.Name", type: "@p.Type", time: localTime.toLocaleString() });
				</text>
				}
			}
				</script>
