@model webGDPR.ViewModels.HWOverviewViewModel
@{
	ViewData["Title"] = "Trackers Overview";
}

<h2>
	<i class="fa fa-gears fa-fw" aria-hidden="true"></i>&nbsp; @ViewData["Title"]
</h2>

<div class="row">
	<div class="col-md-9">
		@{
			var basesDisconnectedToMuch = Model.BaseStats.Where(bs => bs.DisconnectedTimeSpan.TotalHours > 1).ToList();
			if (basesDisconnectedToMuch.Count > 0)
			{
				string[] names = basesDisconnectedToMuch.Select(b => b.Base.Name).ToArray();
				<div class="alert alert-danger">
					<strong>Danger!</strong> These bases are disconnected to much: @string.Join(",", names).
				</div>
			}
		}

		@{
			var collarsDisconnectedToMuch = Model.CollarStats.Where(bs => bs.DisconnectedTimeSpan.TotalHours > 1).ToList();
			if (collarsDisconnectedToMuch.Count > 0)
			{
				string[] names = collarsDisconnectedToMuch.Select(b => b.Collar.Name).ToArray();
				<div class="alert alert-danger">
					<strong>Danger!</strong> These collars are disconnected to much: @string.Join(",", names).
				</div>
			}
		}

		@{
			var collarsGPSDisconnectedToMuch = Model.CollarStats.Where(bs => bs.GPSDisconnectedTimeSpan.TotalHours > 2).ToList();
			if (collarsGPSDisconnectedToMuch.Count > 0)
			{
				string[] names = collarsGPSDisconnectedToMuch.Select(b => b.Collar.Name).ToArray();
				<div class="alert alert-danger">
					<strong>Danger!</strong> These collars are gps disconnected to much: @string.Join(",", names).
				</div>
			}
		}

		@{
			var collarsBatteryLowToMuch = Model.CollarStats.Where(bs => bs.BatteryMinus25Minutes > (5*60)).ToList();
			if (collarsBatteryLowToMuch.Count > 0)
			{
				string[] names = collarsBatteryLowToMuch.Select(b => b.Collar.Name).ToArray();
				<div class="alert alert-danger">
					<strong>Danger!</strong> These collars have battery too low: @string.Join(",", names).
				</div>
			}
		}

		@{
			var basesChargingToMuch = Model.BaseStats.Where(bs => bs.BatteriesChargingMore75percent).ToList();
			if (basesChargingToMuch.Count > 0)
			{
				string[] names = basesChargingToMuch.Select(b => b.Base.Name).ToArray();
				<div class="alert alert-warning">
					<strong>Warning!</strong> These bases are charging to much: @string.Join(",", names).
				</div>
			}
		}

		<div class="well well-sm">
			Most Connected to Device: @Model.MostConnectedToDevice.AliasName
		</div>

		<div class="well well-sm">
			Most Connected to Base: @Model.MostConnectedToBase.Name
		</div>

		<div class="btn-group" role="group" aria-label="..." style="float:right;">
			<button class="btn btn-default active" id="btnHWWeek" data-period="W">last week</button>
			<button class="btn btn-default" id="btnHWMonth" data-period="M">last month</button>
			<button class="btn btn-default" id="btnHWSemester" data-period="S">last 6 months</button>
		</div>

		<div id="HWStats" class="well well-lg" style="margin-top:10px;">
			<partial name="_HWStatsPartial" model="@Model" />
		</div>
	</div>
<style>
	.checklist-ul {
		list-style-type: none;
		padding: 0;
	}
	.checklist-ul li {
		padding: 0 0 0 25px;
		position: relative;
		margin-bottom: 5px;
	}
	.checklist-ul li:before {
		position: absolute;
		left: 5px;
		content: "\2713";
		color: #666;
	}
	</style>
	<div class="col-md-3">
		<h2>CheckList</h2>
		<ul class="checklist-ul">
			<li>Verify that our application is running on your devices or computers. <a>How to verify that?</a></li>
			<li>Verify that your devices or computers connecting to us have internet access.</li>
			<li>Keep your base closed to any of your mobile devices or plugin to any of your computers.</li>
			<li>Keep your base plugin to power most of the time to avoid them consuming the battery.</li>
			<li>Put your base in a place free of radio interferences, such as microwaves.</li>
			<li>Change the collar battery when run out of charge.</li>
			<li>Be sure to recharge the battery removed from the collar.</li>
			<li>Check the bad service places marked in the map for reasons of interference, such as near big metalic or cement structures. If possible, block any access to these places.</li>
		</ul>
	</div>
	</div>

